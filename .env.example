# Sprint Command Center — environment variables
# Copy to .env for local dev, or set in Netlify dashboard.
#
# Neon (recommended for Netlify — free serverless Postgres):
#   1. Sign up at https://neon.tech
#   2. Create a project, copy the POOLED connection string (ends in -pooler)
#   3. Set DATABASE_URL in Netlify → Site settings → Environment variables
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public"

# OPTIONAL: For Neon, also set a DIRECT (non-pooled) URL for migrations.
# Uncomment directUrl in prisma/schema.prisma and set this if you hit
# "prepared statement" errors during prisma migrate deploy.
# DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"
